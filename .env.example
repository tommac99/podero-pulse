# Your Anthropic API key — get one at console.anthropic.com
# Users enter this in the UI; it is never stored server-side
ANTHROPIC_API_KEY=sk-ant-...

# Resend API key for email delivery — get a free key at resend.com
RESEND_API_KEY=re_...

# The verified "from" address in your Resend account
# On free tier you can use: onboarding@resend.dev (sends to your own email only)
RESEND_FROM_EMAIL=onboarding@resend.dev
